---
import BaseLayout from "../layouts/BaseLayout.astro";
import FilterBar from "../components/FilterBar.astro";
import PropertyCard from "../components/PropertyCard.astro";
import properties from "../data/properties.json";

const locale = "en";
const [feature, ...rest] = properties;
---
<BaseLayout title="Magazine · PropertyFlow" current="magazine" locale={locale}>
  <section class="page-head">
    <h1>Magazine</h1>
    <p>Editorial hierarchy. One feature property anchors the page; supporting listings orbit around it.</p>
  </section>
  <FilterBar locale={locale} />
  <div class="grid-mag">
    <div class="grid-mag__feature">
      <PropertyCard prop={feature} variant="magazine" locale={locale} feature={true} />
    </div>
    <div class="grid-mag__rest">
      {rest.map((prop) => (
        <PropertyCard prop={prop} variant="classic" locale={locale} />
      ))}
    </div>
  </div>
  <div class="no-results" data-pf-empty style="display:none;">No properties match these filters.</div>

  <style>
    .grid-mag { display: grid; grid-template-columns: 1fr; gap: 18px; }
    @media (min-width: 920px) {
      .grid-mag { grid-template-columns: 1.1fr 1fr; align-items: flex-start; }
    }
    .grid-mag__rest {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 14px;
    }
  </style>
</BaseLayout>
