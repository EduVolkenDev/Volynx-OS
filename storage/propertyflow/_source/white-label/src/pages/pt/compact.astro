---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FilterBar from "../../components/FilterBar.astro";
import PropertyCard from "../../components/PropertyCard.astro";
import properties from "../../data/properties.json";

const locale = "pt";
---
<BaseLayout title="Lista Compacta · PropertyFlow" current="compact" locale={locale}>
  <section class="page-head">
    <h1>Lista Compacta</h1>
    <p>Busca por filtros. Máxima informação por scroll — ideal para aluguéis e comercial.</p>
  </section>
  <FilterBar locale={locale} />
  <div class="grid-compact">
    {properties.map((prop) => (
      <PropertyCard prop={prop} variant="compact" locale={locale} />
    ))}
  </div>
  <div class="no-results" data-pf-empty style="display:none;">Nenhum imóvel encontrado para esses filtros.</div>

  <style>
    .grid-compact { display: grid; gap: 12px; }
  </style>
</BaseLayout>
