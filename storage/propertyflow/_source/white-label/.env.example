# PropertyFlow Professional — Supabase backend.
# Create a Supabase project (free tier is fine), apply supabase/schema.sql,
# then paste the URL + anon key below.
#
# Get them from: Supabase Dashboard → Project Settings → API

PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

# Optional — site identity
PUBLIC_SITE_NAME="Your Agency"
PUBLIC_CONTACT_EMAIL="contact@youragency.com"
